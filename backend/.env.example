# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000

# --- Database (required) ---
# SQLAlchemy URL, e.g. mysql+pymysql://user:password@127.0.0.1:3306/astra
DATABASE_URL=

# --- Qdrant (vector store; defaults shown) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=

# --- LLM (Ollama-compatible /api/generate; defaults shown) ---
# LLM_URL=http://localhost:11434/api/generate
# LLM_MODEL=mistral

# --- OTP Configuration ---
# If the phone number entered matches this, it will send a real SMS via Twilio.
# For all other numbers, it will just print the OTP in the terminal window.
MY_REAL_PHONE=YOUR_PHONE_NUMBER_HERE_WITHOUT_COUNTRY_CODE  # e.g., 9876543210

# --- Twilio Configuration (Optional) ---
# Fill these if you want to test real SMS sending.
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_NUMBER_HERE   # e.g., +1234567890
