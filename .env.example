# --- App server ---
HOST=0.0.0.0
PORT=8000

# --- Public ports on your machine ---
UI_PORT=80
BACKEND_PORT=8000

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=astra
# Keep this in sync with the MySQL settings above.
DATABASE_URL=mysql+pymysql://root:root@db:3306/astra

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# --- Frontend build ---
# For local access through http://localhost keep this as-is.
# If you open the app via a server IP or hostname, set this before rebuilding:
# VITE_API_BASE=http://your-server-ip
VITE_API_BASE=http://localhost:80

# --- External Ollama / LLM ---
# Docker default is host.docker.internal:11434 — that only works if Ollama runs on the host.
# For RunPod, use your proxy base with /api/generate (same model must exist on the pod).
# LLM_URL=https://YOUR_ID-11434.proxy.runpod.net/api/generate
LLM_URL=http://host.docker.internal:11434/api/generate
LLM_MODEL=mistral
# Optional: only if your proxy requires Authorization (e.g. some RunPod setups).
# OLLAMA_API_TOKEN=runpod
# Optional: use GPU embeddings on the same Ollama (768-dim nomic); must match Qdrant collection size.
# GPU_EMBED_URL=https://YOUR_ID-11434.proxy.runpod.net/api/embeddings
# EMBEDDING_MODEL=nomic-embed-text

# --- OTP / Twilio (optional) ---
MY_REAL_PHONE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Agent / processing tuning (optional) ---
USE_MULTI_AGENT=true
USE_AGENTIC_CHAT=true
AGENTIC_DEBUG=false
CATEGORY_TIMEOUT_SECONDS=15
CATEGORY_CONCURRENCY=5
